# Trading 212 Configuration
T212_ENV=demo  # or 'live' for real trading
T212_API_KEY=YOUR_KEY
T212_API_SECRET=YOUR_SECRET
T212_PIE_ID=your_pie_id_here  # Optional: specific pie to analyze

# Financial Data APIs
FINNHUB_API_KEY=YOUR_KEY

# LLM Rate Limiting
# CRITICAL: Gemini free tier = 10 RPM. With 3 Gemini agents in parallel, each making multiple calls:
# - Set to 1 for safe operation (slower but won't hit limits)
# - Set to 2 for moderate speed (may occasionally hit limits and auto-retry)
# Pipeline will take longer but ensures agents get real-time web data via google_search
GENAI_LLM_RPM=1  # Recommended: 1 for Gemini free tier

# Google Gemini (Required for Growth, Technical, Valuation agents with google_search)
GEMINI_API_KEY=YOUR_GEMINI_KEY
GEMINI_MODEL=gemini/gemini-2.0-flash-exp  # Optional

# Model Configuration (Optional)
# The system will auto-detect which provider to use based on available API keys
# Priority: Azure > OpenAI > Gemini
# You can override the auto-detection by setting MODEL_PREFERENCE to: azure, openai, or gemini
MODEL_PREFERENCE=azure

# Azure OpenAI (Optional - used if MODEL_PREFERENCE=azure or auto-detected)
AZURE_API_BASE=https://your-resource.cognitiveservices.azure.com
AZURE_API_KEY=YOUR_AZURE_KEY
AZURE_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_API_VERSION=2024-12-01-preview

# OpenAI (Optional - used if MODEL_PREFERENCE=openai or auto-detected)
OPENAI_API_KEY=YOUR_OPENAI_KEY
OPENAI_MODEL=gpt-4o-mini

# Gemini (Optional - used if MODEL_PREFERENCE=gemini or auto-detected)
# GEMINI_API_KEY is already set above
GEMINI_MODEL=gemini/gemini-2.0-flash-exp